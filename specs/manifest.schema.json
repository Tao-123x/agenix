{
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "name",
    "version",
    "description",
    "tools",
    "outputs",
    "verifiers"
  ],
  "properties": {
    "path": { "type": "string" },
    "apiVersion": { "type": "string" },
    "kind": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "verifiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "name"],
        "properties": {
          "type": { "type": "string" },
          "name": { "type": "string" },
          "cmd": { "type": "string" },
          "run": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cwd": { "type": "string" },
          "schemaRef": { "type": "string" },
          "policy": {
            "type": "object",
            "properties": {
              "executable": { "type": "string" },
              "cwd": { "type": "string" },
              "timeout_ms": { "type": "integer" }
            }
          },
          "success": {
            "type": "object",
            "properties": {
              "exit_code": { "type": "integer" }
            }
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "properties": {
        "network": { "type": "boolean" },
        "filesystem": {
          "type": "object",
          "properties": {
            "read": {
              "type": "array",
              "items": { "type": "string" }
            },
            "write": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "shell": {
          "type": "object",
          "properties": {
            "allow": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "run": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "requires": {
          "type": "object",
          "properties": {
            "tool_calling": { "type": "boolean" },
            "structured_output": { "type": "boolean" },
            "max_context_tokens": { "type": "integer" },
            "reasoning_level": { "type": "string" }
          }
        }
      }
    },
    "redaction": {
      "type": "object",
      "properties": {
        "keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "regex", "secret_group"],
            "properties": {
              "name": { "type": "string" },
              "regex": { "type": "string" },
              "secret_group": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
